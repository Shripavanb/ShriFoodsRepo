@{
    var pageTitle = ViewData["Title"] ?? "Shri Foods";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <header class="navbar">
        <div class="container nav-container">
            <a asp-page="/Index" class="logo">
                <img src="~/img/logo/NewLogo_Small_1.png" width="150" height="100"/>
                @* <span class="brand-main">Shri</span> Foods *@
            </a>

            <nav class="nav-links">
                <a asp-page="/Index">Home</a>
                <a asp-page="/Index#products">Products</a>
                <a asp-page="/Index#about">About</a>
                <a asp-page="/Index#contact">Contact</a>
            </nav>

            <div class="nav-contact">
                <a href="tel:+918374499001" class="call-btn">📞 Call Now</a>
            </div>

            <div class="menu-toggle" onclick="toggleMenu()">☰</div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container footer-grid">

            <div>
                <h3>Shri Foods</h3>
                <p>Pure • Fresh • Natural</p>
                <p>Premium quality grains & flour for healthy living.</p>
            </div>

            <div>
                <h4>Quick Links</h4>
                <ul>
                    <li><a asp-page="/Index">Home</a></li>
                    <li><a asp-page="/Index#products">Products</a></li>
                    <li><a asp-page="/Index#contact">Contact</a></li>
                </ul>
            </div>

            <div>
                <h4>Contact</h4>
                <p>📞 +91 8374499001</p>
                <p>✉ shripavanb@shrifoods.in</p>
            </div>

        </div>

        <div class="footer-bottom">
            © @DateTime.Now.Year Shri Foods. All Rights Reserved-Powered by <a href="https://shriaitech.in" target="_blank">Shri AI tech</a>.
        </div>
    </footer>

    <!-- WhatsApp Floating Button -->
    <a href="https://wa.me/918374499001" class="whatsapp-float" target="_blank">
        💬
    </a>

    <script>
        function toggleMenu() {
            document.querySelector(".nav-links").classList.toggle("active");
        }
    </script>

</body>
</html>
